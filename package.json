{
  "name": "soap-calc",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:oils": "npm run build -w @soap-calc/oils-data",
    "build:web": "npm run build -w @soap-calc/web",
    "dev:web": "npm run dev -w @soap-calc/web",
    "validate:oils": "npm run validate -w @soap-calc/oils-data",
    "test": "npm run validate:oils && npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
